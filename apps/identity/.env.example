NEXT_PUBLIC_APP_ENV=local
NEXT_PUBLIC_PLATFORM_VERSION=0.1.0
NEXT_PUBLIC_ENABLE_REACT_SCAN=false

# ─── CAS / OAuth2 ─────────────────────────────────────────────────────────
# Base URL of the CAS auth server (no trailing slash)
CAS_ISSUER_URL=http://localhost:9000

# Confidential BFF client registered in CAS (see civis-core AUTHENTICATION.md)
CAS_BFF_CLIENT_ID=01KQPBGXNJP42BRCXGY6W8Y29W
CAS_BFF_CLIENT_SECRET=dev-web-secret

# Public base URL of this Juris deployment (no trailing slash).
# The callback URI <JURIS_BASE_URL>/<locale>/auth/callback must be registered
# in CAS under oauth_client_redirect_uris for the BFF client.
JURIS_BASE_URL=http://localhost:3000

# Base URL of civis-core API (default: CAS_ISSUER_URL with port 9000→8080)
# Set explicitly in staging/production where the two services have different hostnames
# CIVIS_CORE_URL=http://localhost:8080

# ─── Session encryption ────────────────────────────────────────────────────
# 64-char hex string (32 random bytes).  Must be identical across all Juris
# apps in the same deployment.  Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=change-me-use-a-real-64-hex-char-secret-in-all-envs

# Set to "true" to bypass real CAS and return the mock session (local dev only)
# USE_MOCK_SESSION=true
