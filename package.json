{
  "name": "juris",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.2.2",
  "engines": {
    "node": ">=20.18.0"
  },
  "scripts": {
    "dev": "pnpm dev:check && turbo run dev --parallel --continue",
    "dev:check": "tsx tooling/scripts/dev/check-ports.ts",
    "dev:gateway": "pnpm --filter @juris/gateway dev",
    "dev:public": "pnpm --filter @juris/public dev",
    "dev:identity": "pnpm --filter @juris/identity dev",
    "dev:console": "pnpm --filter @juris/console dev",
    "dev:admin": "pnpm --filter @juris/admin dev",
    "dev:billing": "pnpm --filter @juris/billing dev",
    "dev:reporting": "pnpm --filter @juris/reporting dev",
    "dev:settings": "pnpm --filter @juris/settings dev",
    "dev:support": "pnpm --filter @juris/support dev",
    "build": "turbo run build --concurrency=2",
    "lint": "turbo run lint --concurrency=4",
    "typecheck": "turbo run typecheck --concurrency=4",
    "test": "turbo run test --concurrency=4",
    "test:watch": "turbo run test:watch --parallel",
    "test:coverage": "turbo run test:coverage --concurrency=4",
    "test:e2e": "playwright test",
    "storybook": "pnpm --filter @repo/ui storybook",
    "storybook:build": "pnpm --filter @repo/ui storybook:build",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "knip": "knip",
    "changeset": "changeset",
    "release:check": "tsx tooling/scripts/release/ensure-changeset.ts",
    "release:version": "tsx tooling/scripts/release/version.ts",
    "release:notes": "tsx tooling/scripts/release/print-latest-changelog.ts",
    "cloudflare:matrix": "tsx tooling/scripts/cloudflare/print-matrix.ts",
    "cloudflare:plan": "tsx tooling/scripts/cloudflare/plan.ts",
    "cloudflare:validate": "tsx tooling/scripts/cloudflare/validate.ts",
    "cloudflare:deploy": "tsx tooling/scripts/cloudflare/deploy.ts",
    "cloudflare:destroy": "tsx tooling/scripts/cloudflare/destroy.ts",
    "cloudflare:smoke": "tsx tooling/scripts/cloudflare/smoke-test.ts",
    "analyze": "ANALYZE=true turbo run build --concurrency=2",
    "bootstrap": "tsx tooling/scripts/bootstrap.ts",
    "codehawk": "tsx tooling/scripts/codehawk.ts",
    "validate:manifests": "tsx tooling/scripts/validate-manifests.ts",
    "validate:architecture": "tsx tooling/scripts/validate-architecture.ts",
    "validate:i18n": "tsx tooling/scripts/validate-i18n.ts",
    "validate:deployment": "pnpm cloudflare:validate",
    "validate": "pnpm typecheck && pnpm lint && pnpm format:check && pnpm validate:architecture && pnpm validate:manifests && pnpm validate:i18n && pnpm validate:deployment && pnpm test && pnpm build",
    "clean": "turbo run clean --concurrency=8 && find apps packages -name '*.tsbuildinfo' -delete && rm -rf .turbo coverage playwright-report test-results packages/ui/storybook-static",
    "dev:docs": "pnpm --filter @juris/docs dev"
  },
  "devDependencies": {
    "@changesets/cli": "^2.29.7",
    "@eslint/js": "9.39.4",
    "@next/bundle-analyzer": "15.5.18",
    "@next/eslint-plugin-next": "15.5.18",
    "@opennextjs/cloudflare": "1.19.11",
    "@playwright/test": "^1.57.0",
    "@storybook/addon-docs": "10.4.1",
    "@storybook/react-vite": "10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitest/coverage-v8": "4.1.7",
    "autoprefixer": "^10.4.22",
    "eslint": "9.39.4",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "jsdom": "^27.3.0",
    "knip": "^5.71.0",
    "playwright": "^1.57.0",
    "postcss": "^8.5.6",
    "prettier": "^3.7.4",
    "prettier-plugin-tailwindcss": "^0.7.1",
    "storybook": "10.4.1",
    "tailwindcss": "^3.4.18",
    "turbo": "2.9.14",
    "tsx": "^4.21.0",
    "typescript": "5.8.3",
    "typescript-eslint": "8.49.0",
    "vite": "^7.2.7",
    "vitest": "4.1.7",
    "wrangler": "^4.57.1"
  }
}
